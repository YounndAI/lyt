{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": ".",
    "rootDir": "."
  },
  "include": ["main.ts"],
  "exclude": ["node_modules", "tests"]
}
